# ── HTTP ────────────────────────────────────────────────────────────────────
PORT=8787

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Matches docker-compose.yml credentials and host port mapping.
DATABASE_URL=postgresql://rotom:rotom@localhost:5433/rotom

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── Auth ──────────────────────────────────────────────────────────────────────
# Optional. If left blank, the backend generates a token on first boot, prints
# it once, and writes it to `.rotom-token`. Only its SHA-256 hash is stored.
API_TOKEN=

# ── Encryption at rest ──────────────────────────────────────────────────────
# REQUIRED. 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=

# ── Claude Code CLI (AI layer) ──────────────────────────────────────────────
# Auth: by default the AI layer uses the logged-in `claude` subscription token
# (~/.claude/.credentials.json) — run `claude login` once and leave this blank.
# Set it only to override with an API key (the CLI then prefers it).
ANTHROPIC_API_KEY=
# Path/name of the claude binary on PATH.
CLAUDE_BIN=claude
# Model alias or full name (e.g. "opus", "claude-opus-4-8").
CLAUDE_MODEL=claude-opus-4-8
# Hard timeout (ms) for a single generation subprocess.
CLAUDE_TIMEOUT_MS=60000
# Per-invocation spend ceiling passed to the CLI (USD).
CLAUDE_MAX_BUDGET_USD=1.00

# ── Generation queue (BullMQ) ───────────────────────────────────────────────
# How many generation jobs the in-process worker handles concurrently.
GENERATION_CONCURRENCY=3
# Redis key prefix for BullMQ.
QUEUE_PREFIX=rotom

# ── Job-description URL fetching ────────────────────────────────────────────
JD_FETCH_TIMEOUT_MS=10000
JD_FETCH_MAX_BYTES=2000000
JD_FETCH_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0 Rotom/0.1

# ── Misc ──────────────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development
LOG_LEVEL=info
